# Cultural Lens — Environment Variables
# Copy this file to .env and fill in your keys.

# Primary API — Groq (fastest, free)
VITE_GROQ_KEY=your_groq_key_here

# Fallback API — OpenRouter (free credits)
VITE_OPENROUTER_KEY=your_openrouter_key_here

# Last-resort API — Google Gemini
VITE_GEMINI_KEY=your_gemini_key_here
